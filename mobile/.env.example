# ─────────────────────────────────────────────────────────────────────────────
# ByteShards mobile — environment template.
# Copy this file to `.env` and fill in the values. `.env` is gitignored.
# Every value is OPTIONAL: leave a section blank and that feature falls back to a
# safe stub (offline store / mock purchase / no-op analytics). See SETUP.md.
# All client-exposed vars MUST be prefixed EXPO_PUBLIC_ for Expo to inject them.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — Project Settings → Data API / API Keys (https://supabase.com/dashboard)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# PostHog — Project Settings → Project API Key (https://posthog.com)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Branch — Dashboard → Account Settings → Branch Key (https://dashboard.branch.io)
# (Install attribution; requires the native module + a dev build — see SETUP.md.)
EXPO_PUBLIC_BRANCH_KEY=

# Google Sign-In — Google Cloud Console → OAuth 2.0 Web client ID
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# In-app purchase base product id (create as a NON-CONSUMABLE in App Store Connect + Play Console).
# One-off pack ids live in src/lib/products.ts (each also a non-consumable IAP).
EXPO_PUBLIC_IAP_PRODUCT_ID=fieldnotes_pro_lifetime

# "Stay current" content manifest (public read-only URL). When set, the app version-checks it
# on launch and pulls new fresh cards over-the-air. Produced by tooling/content/publish.mjs.
# Leave blank → app uses the bundled fresh seed only.
EXPO_PUBLIC_CONTENT_MANIFEST_URL=

# NOTE: the content pipeline's SUPABASE_SERVICE_ROLE_KEY is SERVER-ONLY and lives in
# tooling/content/.env — NEVER add a service-role key here (EXPO_PUBLIC_* is baked into the app).
