# Content tooling environment (SERVER-ONLY — never expose these to the mobile app).
# Copy to tooling/content/.env. The manual path (add.mjs / publish.mjs dry-run) needs NONE of these.

# Required only for the optional automated ingest (run.mjs):
ANTHROPIC_API_KEY=
# Optional model overrides:
# CONTENT_MODEL=claude-sonnet-4-6
# VERIFY_MODEL=claude-opus-4-8

# Required only to upload from publish.mjs --yes (otherwise it writes out/ for manual upload):
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
