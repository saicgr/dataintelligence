# ─────────────────────────────────────────────────────────────────────────────
# ByteShards env. The app builds + runs with NONE of these set (seed mode).
# Add a group to flip that subsystem to live — no code changes required.
# Copy to .env.local and fill in what you want active.
# ─────────────────────────────────────────────────────────────────────────────

# Public site URL (used for OG images, canonicals, Stripe redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase (Auth + Postgres) ──────────────────────────────────────────────
# Without these: mock user owns every sheet; progress persists in localStorage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, used by the Stripe webhook + job ingestion.
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (one-time payments) ──────────────────────────────────────────────
# Without these: /buy + checkout return a friendly "configure Stripe" stub.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Gemini (AI interviewer "Dawn" + answer grading on /practice) ─────────────
# Without this: the interviewer is scripted and grading falls back to a rubric.
GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-flash)
GEMINI_MODEL=

# ── PySpark runner (optional) ────────────────────────────────────────────────
# Server-side Spark in local mode (see spark-runner/). dev.sh starts it when
# Java + pyspark are installed; otherwise PySpark practice falls back to AI-eval.
SPARK_RUNNER_URL=http://localhost:4000

# ── Job ingestion (optional) ────────────────────────────────────────────────
# Comma-separated Greenhouse board tokens and Lever company slugs to ingest.
JOBS_GREENHOUSE_BOARDS=stripe,airbnb,databricks
JOBS_LEVER_COMPANIES=
# Secret to protect the /api/jobs/ingest cron endpoint.
CRON_SECRET=
